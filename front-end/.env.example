# URL base de tu backend Express (sin barra final)
# En desarrollo local:
VITE_API_URL=http://localhost:3000

# En producción, cámbiala por donde despliegues el backend
# (Render, Railway, Fly.io, un VPS, etc). NOTA: un servidor Express con
# app.listen() no corre en Vercel como sitio estático — Vercel solo sirve
# tu front-end (ver front-end/vercel.json). El backend necesita un host
# que mantenga un proceso Node corriendo.
# VITE_API_URL=https://sistemas-inteligentes-backend.vercel.app/
